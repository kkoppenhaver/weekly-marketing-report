# Storage backend: "local" for dev (writes to ./snapshots/), "r2" for production
STORAGE=local

# Site under analysis
SITE_URL=https://claudecodeformarketers.com
SITE_REPO=kkoppenhaver/claude-code-for-marketers
# Local path used by fetch-post-manifest in dev. In the Routine, the repo is cloned fresh.
SITE_REPO_LOCAL=~/code/claude-code-for-marketers
CONTENT_PATH=src/content/blog

# GitHub (only needed in the Routine; local dev reads from SITE_REPO_LOCAL)
GITHUB_TOKEN=

# Cloudflare R2 (used when STORAGE=r2)
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_ENDPOINT=
R2_BUCKET=claudecodeformarketers-reports

# Google Search Console (OAuth — service-account path is broken by a confirmed Google bug)
GSC_PROPERTY=https://claudecodeformarketers.com/
GSC_OAUTH_CLIENT_JSON=~/.config/cc4m-report/auth.json
GSC_OAUTH_TOKEN_JSON=~/.config/cc4m-report/oauth-token.json

# Fathom Analytics
FATHOM_API_KEY=
FATHOM_SITE_ID=

# Kit (ConvertKit)
KIT_API_KEY=
KIT_PRIMARY_TAG_ID=14154457   # Default CC4M tag — applied to all signups (see site repo CLAUDE.md)
# KIT_FORM_IDS=               # Optional comma-separated form IDs to break out

# PageSpeed Insights
PSI_API_KEY=

# DataForSEO
DFS_LOGIN=
DFS_PASSWORD=

# Google Drive (report doc destination)
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=

# Resend (email delivery)
RESEND_API_KEY=
REPORT_TO_EMAIL=
REPORT_FROM_EMAIL=
